{
  "manifest_version": 3,
  "name": "링크 포켓 (Link Pocket)",
  "version": "1.0",
  "description": "우클릭으로 간편하게 링크를 분류하고 저장하는 포켓 (사이드바 버전)",
  "permissions": ["contextMenus", "storage", "tabs", "sidePanel"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "링크 포켓 열기",
    "default_icon": "icon.png"
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}
